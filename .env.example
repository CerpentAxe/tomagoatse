# PostgreSQL connection (required for accounts and saving creatures)
# Local: postgres://user:pass@localhost:5432/tomagoatse
# Supabase: Project Settings → Database → Connection string → URI.
#   Choose "Session pooler" (or Direct). Paste the full postgresql://... line — no app code change.
#   Transaction pooler (port 6543) works for many apps but Session/Direct fits this server + sessions better.
#   Special characters in the password must be URL-encoded.
# TLS is enabled automatically for supabase.co / neon.tech / render.com hosts; for local Postgres
# without SSL set DATABASE_SSL=false
DATABASE_URL=
# DATABASE_SSL=false
# Optional: full TLS cert verification (default off for Supabase URLs to avoid SELF_SIGNED_CERT_IN_CHAIN on Render)
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Session cookie signing (use a long random string in production)
SESSION_SECRET=

# Admin panel at /admin.html — list all accounts and creatures. Min 12 characters; never commit the real value.
# Set on Render (or local .env). The page sends this as Bearer or X-Admin-Secret.
ADMIN_SECRET=

# Fine-grained token with "Make calls to Inference Providers":
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
HF_API_KEY=hf_your_token_here

# Chat + image models (Inference Providers / router.huggingface.co)
# Chat ids should include a routing suffix (e.g. :fastest). If you set only org/model,
# the server appends :fastest automatically.
#
# If you see model_not_supported / "not supported by any provider you have enabled",
# pick a model your token can use, or enable providers at:
# https://huggingface.co/settings/inference-providers
# Good defaults: Qwen or Llama (below). Mistral and others may require specific providers.
# HF_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
# Optional extra chat models (tried after the built-in Qwen/Llama fallbacks):
# HF_TEXT_MODEL_FALLBACKS=mistralai/Mistral-7B-Instruct-v0.2:fastest
# HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Portal: hours after AI round before “Continue the conversation” unlocks (default 12).
# PORTAL_CONTINUE_HOURS=12
